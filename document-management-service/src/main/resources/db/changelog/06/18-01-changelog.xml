<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.8.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1750224998440-1" author="vadim">
        <createTable tableName="document_signature">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_document_signature"/>
            </column>
            <column name="document_version_id" type="BIGINT"/>
            <column name="signature" type="BLOB"/>
            <column name="signature_algorithm" type="VARCHAR(255)"/>
            <column name="certificate_subject" type="VARCHAR(255)"/>
            <column name="certificate_issuer" type="VARCHAR(255)"/>
            <column name="certificate_serial_number" type="VARCHAR(255)"/>
            <column name="signed_at" type="DATETIME"/>
            <column name="signed_by" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>
    <changeSet id="1750224998440-2" author="vadim">
        <addColumn tableName="document_version">
            <column name="hash" type="VARCHAR(255)"/>
        </addColumn>
    </changeSet>
    <changeSet id="1750224998440-3" author="vadim">
        <addForeignKeyConstraint baseColumnNames="document_version_id" baseTableName="document_signature"
                                 constraintName="FK_DOCUMENT_SIGNATURE_ON_DOCUMENT_VERSION" referencedColumnNames="id"
                                 referencedTableName="document_version"/>
    </changeSet>
    <changeSet id="1750224998440-4" author="vadim">
        <dropColumn columnName="signature" tableName="document_version"/>
    </changeSet>

</databaseChangeLog>